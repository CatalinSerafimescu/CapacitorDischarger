    (property "Datasheet" "" (at 0 0 0) (effects (font (size 1.27 1.27)) hide))
    (pin "G" (uuid "a1000031-0001-0001-0001-000000000101"))
    (pin "D" (uuid "a1000031-0001-0001-0001-000000000102"))
    (pin "S" (uuid "a1000031-0001-0001-0001-000000000103"))
