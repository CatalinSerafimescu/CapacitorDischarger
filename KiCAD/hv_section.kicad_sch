  ;; ═══════════════════════════════════════════════════════════════════════
  ;; WIRES
  ;; ═══════════════════════════════════════════════════════════════════════

  ;; J1 pin1 → PROBE_A node at (30, 30) horizontal
  (wire (pts (xy 22.54 30) (xy 35 30)) (stroke (width 0) (type default)) (uuid "w0001"))
  ;; J2 pin1 → GND short stub
  (wire (pts (xy 22.54 50) (xy 25 50)) (stroke (width 0) (type default)) (uuid "w0002"))
  (wire (pts (xy 25 50) (xy 25 58)) (stroke (width 0) (type default)) (uuid "w0003"))

  ;; J3 pin1 → PROBE_A at y=68.73 → join (35,30)
  (wire (pts (xy 22.54 68.73) (xy 35 68.73)) (stroke (width 0) (type default)) (uuid "w0004"))
  (wire (pts (xy 35 68.73) (xy 35 30)) (stroke (width 0) (type default)) (uuid "w0005"))
  ;; J3 pin2 → GND node
  (wire (pts (xy 22.54 71.27) (xy 25 71.27)) (stroke (width 0) (type default)) (uuid "w0006"))
  (wire (pts (xy 25 71.27) (xy 25 58)) (stroke (width 0) (type default)) (uuid "w0007"))

  ;; J4 pin1 → PROBE_A node (35,30)
  (wire (pts (xy 22.54 88.73) (xy 35 88.73)) (stroke (width 0) (type default)) (uuid "w0008"))
  (wire (pts (xy 35 88.73) (xy 35 30)) (stroke (width 0) (type default)) (uuid "w0009"))
  ;; J4 pin2 → GND
  (wire (pts (xy 22.54 91.27) (xy 25 91.27)) (stroke (width 0) (type default)) (uuid "w0010"))
  (wire (pts (xy 25 91.27) (xy 25 96)) (stroke (width 0) (type default)) (uuid "w0011"))

  ;; PROBE_A bus (35,30) → D1 anode (56.19, 45): go right then down
  (wire (pts (xy 35 30) (xy 45 30)) (stroke (width 0) (type default)) (uuid "w0020"))
  (wire (pts (xy 45 30) (xy 45 45)) (stroke (width 0) (type default)) (uuid "w0021"))
  (wire (pts (xy 45 45) (xy 56.19 45)) (stroke (width 0) (type default)) (uuid "w0022"))

  ;; PROBE_A also → D3 cathode (right side of D3 at 78.81, 45): connects PROBE_A to D3 K
  (wire (pts (xy 45 45) (xy 56.19 45)) (stroke (width 0) (type default)) (uuid "w0023"))
  ;; Actually D3 K is at (78.81,45) — wire from PROBE_A node through D1 K to D3 K
  ;; D1 K = (63.81, 45), D3 K = (78.81, 45) — both cathodes meet at HV+ bus
  (wire (pts (xy 63.81 45) (xy 78.81 45)) (stroke (width 0) (type default)) (uuid "w0024"))
  ;; HV+ bus right to R_slow1 pin1 (120, 41.19)
  (wire (pts (xy 78.81 45) (xy 100 45)) (stroke (width 0) (type default)) (uuid "w0025"))
  (wire (pts (xy 100 45) (xy 120 41.19)) (stroke (width 0) (type default)) (uuid "w0026"))
  ;; HV+ bus branch to R_fast pin1
  (wire (pts (xy 100 45) (xy 100 35)) (stroke (width 0) (type default)) (uuid "w0027"))
  (wire (pts (xy 100 35) (xy 160 35)) (stroke (width 0) (type default)) (uuid "w0028"))
  (wire (pts (xy 160 35) (xy 160 51.19)) (stroke (width 0) (type default)) (uuid "w0029"))

  ;; PROBE_B — from J2/J3/J4 minus → bridge
  ;; GND-referenced probe node at y=75 left side: D2 A and D4 A are the PROBE_B entry
  ;; Actually in full-bridge: D2 anode = PROBE_B, D4 anode = PROBE_B
  ;; J2 connects to GND (probe minus = circuit GND in this design)
  ;; PROBE_B node at (45, 75)
  (wire (pts (xy 35 30) (xy 35 75)) (stroke (width 0) (type default)) (uuid "w0030"))
  ;; No — PROBE_B is the negative probe, which for a full-bridge goes to the AC2 terminal.
  ;; In this design J1=PROBE_A, J2=PROBE_B(−). Bridge AC1=A-probe, AC2=B-probe.
  ;; J2 → PROBE_B node at (35,75)
  (wire (pts (xy 22.54 50) (xy 35 50)) (stroke (width 0) (type default)) (uuid "w0031"))
  (wire (pts (xy 35 50) (xy 35 75)) (stroke (width 0) (type default)) (uuid "w0032"))
  ;; PROBE_B node → D2 anode (56.19, 75)
  (wire (pts (xy 35 75) (xy 56.19 75)) (stroke (width 0) (type default)) (uuid "w0033"))
  ;; D2 K → HV+ (same bus as D1 K): (63.81, 75) wire up to (63.81, 45) then join HV+ bus
  (wire (pts (xy 63.81 75) (xy 63.81 45)) (stroke (width 0) (type default)) (uuid "w0034"))
  ;; D4 anode (71.19, 75) ← from GND node (bridge DC−)
  (wire (pts (xy 67.5 82) (xy 67.5 75)) (stroke (width 0) (type default)) (uuid "w0035"))
  (wire (pts (xy 67.5 75) (xy 71.19 75)) (stroke (width 0) (type default)) (uuid "w0036"))
  ;; D4 K (78.81, 75) → PROBE_B return: connects back to PROBE_B node at (35,75)? No.
  ;; D4 K should connect to PROBE_B = (35,75)? No, D4 K goes to PROBE_B (AC2).
  ;; In full bridge: D4 K = AC2 = PROBE_B
  (wire (pts (xy 78.81 75) (xy 90 75)) (stroke (width 0) (type default)) (uuid "w0037"))
  (wire (pts (xy 90 75) (xy 90 50)) (stroke (width 0) (type default)) (uuid "w0038"))
  (wire (pts (xy 90 50) (xy 35 50)) (stroke (width 0) (type default)) (uuid "w0039"))
  ;; D3 anode (56.19, 45) ← from GND node
  (wire (pts (xy 67.5 82) (xy 67.5 45)) (stroke (width 0) (type default)) (uuid "w0040"))
  ;; Actually D3 is bottom-left: A=GND_node, K=PROBE_A
  ;; D3 at (75,45): A at (71.19,45), K at (78.81,45)
  ;; D3 A (71.19,45) ← GND node at (67.5,82) — too far up
  ;; Let me re-route: bridge GND node at (67.5, 45+82)/2 area...
  ;; Simplify: bridge GND node is at (67.5, 60) centre; run short stubs.
  ;; D3 A = (71.19,45), D4 A = (71.19,75) — both connect to bridge GND centre

  ;; Bridge internal GND node at (67.5, 60)
  (wire (pts (xy 67.5 60) (xy 67.5 82)) (stroke (width 0) (type default)) (uuid "w0041"))
  (wire (pts (xy 67.5 60) (xy 71.19 45)) (stroke (width 0) (type default)) (uuid "w0042"))
  (wire (pts (xy 67.5 60) (xy 71.19 75)) (stroke (width 0) (type default)) (uuid "w0043"))

  ;; R_slow series chain wires (pin2 of one → pin1 of next)
  ;; R_slow1 pin2 (120,48.81) → R_slow2 pin1 (120,58.19)
  (wire (pts (xy 120 48.81) (xy 120 58.19)) (stroke (width 0) (type default)) (uuid "w0050"))
  ;; R_slow2 pin2 (120,65.81) → R_slow3 pin1 (120,75.19)
  (wire (pts (xy 120 65.81) (xy 120 75.19)) (stroke (width 0) (type default)) (uuid "w0051"))
  ;; R_slow3 pin2 (120,82.81) → R_slow4 pin1 (120,92.19)
  (wire (pts (xy 120 82.81) (xy 120 92.19)) (stroke (width 0) (type default)) (uuid "w0052"))
  ;; R_slow4 pin2 (120,99.81) → R_slow5 pin1 (120,109.19)
  (wire (pts (xy 120 99.81) (xy 120 109.19)) (stroke (width 0) (type default)) (uuid "w0053"))
  ;; R_slow5 pin2 (120,116.81) → GND symbol (120,123)
  (wire (pts (xy 120 116.81) (xy 120 123)) (stroke (width 0) (type default)) (uuid "w0054"))

  ;; R_fast pin2 (160,58.81) → Q2 drain (160,75)
  (wire (pts (xy 160 58.81) (xy 160 75)) (stroke (width 0) (type default)) (uuid "w0060"))
  ;; Q2 source (160,85) → GND symbol (160,92)
  (wire (pts (xy 160 85) (xy 160 92)) (stroke (width 0) (type default)) (uuid "w0061"))

  ;; ═══════════════════════════════════════════════════════════════════════
  ;; GLOBAL LABELS
  ;; ═══════════════════════════════════════════════════════════════════════

  ;; HV+ global label at (100, 35) — junction of slow and fast path top bus
  (global_label "HV+"
    (shape output)
    (at 100 30 0)
    (effects (font (size 1.27 1.27)) (justify left))
    (uuid "gl0001")
    (property "Intersheet References" "" (at 100 30 0) (effects (font (size 1.27 1.27)) hide))
  )

  ;; GATE global label — connects to Q2 gate (155,80)
  (global_label "GATE"
    (shape input)
    (at 148 80 180)
    (effects (font (size 1.27 1.27)) (justify right))
    (uuid "gl0002")
    (property "Intersheet References" "" (at 148 80 0) (effects (font (size 1.27 1.27)) hide))
  )

  ;; Wire: GATE global label → Q2 gate pin
  (wire (pts (xy 148 80) (xy 155 80)) (stroke (width 0) (type default)) (uuid "w0070"))

  ;; Wire: HV+ label → HV+ bus junction
  (wire (pts (xy 100 30) (xy 100 35)) (stroke (width 0) (type default)) (uuid "w0071"))

  ;; Junction at HV+ bus split (100,35)
  (junction (at 100 35) (diameter 0) (color 0 0 0 0) (uuid "j0001"))
  ;; Junction at PROBE_A bus (35,30) — J1, J3, J4 all meet here
  (junction (at 35 30) (diameter 0) (color 0 0 0 0) (uuid "j0002"))
  ;; Junction at PROBE_B bus (35,50) — J2 meets J3/J4 minus
  (junction (at 35 50) (diameter 0) (color 0 0 0 0) (uuid "j0003"))
  ;; Junction at bridge HV+ node (63.81,45) — D1K and D2K meet
  (junction (at 63.81 45) (diameter 0) (color 0 0 0 0) (uuid "j0004"))
  ;; Junction at bridge GND internal node (67.5,60)
  (junction (at 67.5 60) (diameter 0) (color 0 0 0 0) (uuid "j0005"))

  (sheet_instances
    (path "/"
      (page "1")
    )
  )
)
