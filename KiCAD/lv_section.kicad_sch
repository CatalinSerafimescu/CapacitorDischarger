  ;; R3 pin2 → Q1 base
  (wire (pts (xy 75 52) (xy 87.46 52)) (stroke (width 0) (type default)) (uuid "lw0005"))
  ;; Q1 emitter → GND
  (wire (pts (xy 90.508 57.08) (xy 90.508 62)) (stroke (width 0) (type default)) (uuid "lw0006"))

  ;; ═══════════════════════════════════════════════════════════════════════
  ;; WIRES — Block B
  ;; ═══════════════════════════════════════════════════════════════════════

