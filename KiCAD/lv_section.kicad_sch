  ;; HV+ → R1 pin1
  (wire (pts (xy 50 22) (xy 50 36.19)) (stroke (width 0) (type default)) (uuid "lw0001"))
  ;; R1 pin2 → node_A wire down to R2 pin1
  (wire (pts (xy 50 43.81) (xy 50 59.46)) (stroke (width 0) (type default)) (uuid "lw0002"))
  ;; R2 pin2 → GND
  (wire (pts (xy 50 64.54) (xy 50 70)) (stroke (width 0) (type default)) (uuid "lw0003"))
  ;; node_A → R3 pin1 (horizontal to left of R3)
  (wire (pts (xy 50 52) (xy 70 52)) (stroke (width 0) (type default)) (uuid "lw0004"))
